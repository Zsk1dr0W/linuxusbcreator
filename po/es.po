#: src/app/main.c:44
msgid "Usage:"
msgstr "Uso:"

#: src/app/main.c:55
msgid "Commands:"
msgstr "Comandos:"

#: src/app/main.c:56
msgid "Print detected devices and eligibility as JSON"
msgstr "Muestra los dispositivos detectados y su elegibilidad como JSON"

#: src/app/main.c:57
msgid "Compute SHA-256 for a regular image file"
msgstr "Calcula SHA-256 para un archivo de imagen regular"

#: src/app/main.c:58
msgid "Identify a Linux, Windows, or raw/unknown image as JSON"
msgstr "Identifica una imagen Linux, Windows o raw/desconocida como JSON"

#: src/app/main.c:59
msgid "Inspect a Windows ISO9660/UDF installer as JSON"
msgstr "Inspecciona un instalador ISO9660/UDF de Windows como JSON"

#: src/app/main.c:60
msgid "Mount read-only and validate Windows WIM/ESD payloads"
msgstr "Monta en solo lectura y valida payloads WIM/ESD de Windows"

#: src/app/main.c:61
msgid "Mount read-only and validate the Fedora Live ISO profile"
msgstr "Monta en solo lectura y valida el perfil ISO de Fedora Live"

#: src/app/main.c:62
msgid "Create verified Windows installation media for UEFI/GPT or BIOS/MBR"
msgstr ""
"Crea medios de instalación de Windows verificados para UEFI/GPT o BIOS/MBR"

#: src/app/main.c:63
msgid "Create verified Fedora Live UEFI media with optional persistence"
msgstr "Crea medios Fedora Live UEFI verificados con persistencia opcional"

#: src/app/main.c:64
msgid "Write and verify an image on a confirmed USB device"
msgstr "Escribe y verifica una imagen en un dispositivo USB confirmado"

#: src/app/main.c:65
msgid "Skip read-back verification (not recommended)"
msgstr "Omite la verificación por lectura posterior (no recomendado)"

#: src/app/main.c:66
msgid "Options:"
msgstr "Opciones:"

#: src/app/main.c:67
msgid "Show this help"
msgstr "Muestra esta ayuda"

#: src/app/main.c:68
msgid "Show program version"
msgstr "Muestra la versión del programa"

#: src/app/window.c:63
msgid "ERASE"
msgstr "BORRAR"

#: src/app/window.c:94
msgid "Available; its partitions will be unmounted before writing"
msgstr "Disponible; sus particiones se desmontarán antes de escribir"

#: src/app/window.c:95
msgid "Available for writing"
msgstr "Disponible para escribir"

#: src/app/window.c:98
msgid "Blocked: the device does not report a stable serial number"
msgstr "Bloqueado: el dispositivo no informa un número de serie estable"

#: src/app/window.c:101
msgid "Blocked: no media is available"
msgstr "Bloqueado: no hay medio disponible"

#: src/app/window.c:103
msgid "Blocked: no block device is available"
msgstr "Bloqueado: no existe un dispositivo de bloques"

#: src/app/window.c:105
msgid "Blocked: this is not a USB device"
msgstr "Bloqueado: no es un dispositivo USB"

#: src/app/window.c:107
msgid "Blocked: the device is not removable"
msgstr "Bloqueado: el dispositivo no es extraíble"

#: src/app/window.c:109
msgid "Blocked: contains the current operating system"
msgstr "Bloqueado: contiene el sistema operativo actual"

#: src/app/window.c:111
msgid "Blocked: contains active swap"
msgstr "Bloqueado: contiene swap activa"

#: src/app/window.c:113
msgid "Blocked: the device is read-only"
msgstr "Bloqueado: el dispositivo es de solo lectura"

#: src/app/window.c:115
msgid "Blocked: unsupported device type"
msgstr "Bloqueado: tipo de dispositivo no compatible"

#: src/app/window.c:119
msgid "Blocked by the safety policy"
msgstr "Bloqueado por la política de seguridad"

#: src/app/window.c:135
msgid "no block node"
msgstr "sin nodo de bloques"

#: src/app/window.c:204 src/app/window.c:935
msgid "The image is larger than the selected device."
msgstr "La imagen es más grande que el dispositivo seleccionado."

#: src/app/window.c:221
msgid ""
"Fedora ISO mode uses UEFI/GPT, bundled signed GRUB and mandatory file "
"verification."
msgstr ""
"El modo ISO de Fedora usa UEFI/GPT, el GRUB firmado incluido y verificación "
"obligatoria de archivos."

#: src/app/window.c:227
msgid ""
"Hybrid/raw mode preserves the image layout and supports BIOS and UEFI when "
"provided by the ISO."
msgstr ""
"El modo híbrido/raw conserva la estructura de la imagen y admite BIOS y UEFI "
"cuando la ISO los incluye."

#: src/app/window.c:277
msgid "UDisks2 did not report any storage devices."
msgstr "UDisks2 no informó dispositivos de almacenamiento."

#: src/app/window.c:280
#, c-format
msgid "%u device detected; %u USB available for writing."
msgid_plural "%u devices detected; %u USB devices available for writing."
msgstr[0] "%u dispositivo detectado; %u USB disponible para escribir."
msgstr[1] "%u dispositivos detectados; %u USB disponibles para escribir."

#: src/app/window.c:340
msgid "Select a regular local image file."
msgstr "Selecciona un archivo de imagen regular local."

#: src/app/window.c:353
msgid "The Windows image could not be inspected safely."
msgstr "No fue posible inspeccionar de forma segura la imagen de Windows."

#: src/app/window.c:366
msgid "This Windows image is not compatible with the supported FAT32 profiles."
msgstr ""
"Esta imagen de Windows no es compatible con los perfiles FAT32 admitidos."

#: src/app/window.c:385
#, c-format
msgid "%s · %s · Windows %s · install.wim will be split"
msgstr "%s · %s · Windows %s · install.wim se dividirá"

#: src/app/window.c:386
#, c-format
msgid "%s · %s · Windows %s"
msgstr "%s · %s · Windows %s"

#: src/app/window.c:392 src/app/window.c:393
msgid "UEFI · GPT"
msgstr "UEFI · GPT"

#: src/app/window.c:392
msgid "BIOS · MBR"
msgstr "BIOS · MBR"

#: src/app/window.c:404
msgid ""
"Windows installer detected. Choose UEFI/GPT or BIOS/MBR; files will be "
"verified."
msgstr ""
"Instalador de Windows detectado. Elige UEFI/GPT o BIOS/MBR; los archivos se "
"verificarán."

#: src/app/window.c:408
#, c-format
msgid "%s · %s · %s · %s"
msgstr "%s · %s · %s · %s"

#: src/app/window.c:417
msgid "Hybrid/raw · BIOS and UEFI"
msgstr "Híbrido/raw · BIOS y UEFI"

#: src/app/window.c:418
msgid "ISO · Fedora Live UEFI"
msgstr "ISO · Fedora Live UEFI"

#: src/app/window.c:432
msgid ""
"Linux image detected. Hybrid/raw writing with full verification will be used."
msgstr ""
"Imagen Linux detectada. Se usará escritura híbrida/raw con verificación "
"completa."

#: src/app/window.c:435
#, c-format
msgid "%s · %s · Raw or unrecognized image"
msgstr "%s · %s · Imagen raw o no reconocida"

#: src/app/window.c:442
msgid "Select a USB device and review verification before continuing."
msgstr "Selecciona un USB y revisa la verificación antes de continuar."

#: src/app/window.c:460
msgid "Select disk image"
msgstr "Seleccionar imagen de disco"

#: src/app/window.c:463
msgid "Select"
msgstr "Seleccionar"

#: src/app/window.c:463 src/app/window.c:890 src/app/window.c:994
msgid "Cancel"
msgstr "Cancelar"

#: src/app/window.c:465
msgid "Disk images (*.iso, *.img, *.raw)"
msgstr "Imágenes de disco (*.iso, *.img, *.raw)"

#: src/app/window.c:473
msgid "All files"
msgstr "Todos los archivos"

#: src/app/window.c:501
#, c-format
msgid "Elapsed time: %02u:%02u"
msgstr "Tiempo transcurrido: %02u:%02u"

#: src/app/window.c:534
msgid "Computing the image SHA-256…"
msgstr "Calculando SHA-256 de la imagen…"

#: src/app/window.c:540
msgid "Validating the Windows installer…"
msgstr "Validando el instalador de Windows…"

#: src/app/window.c:546
msgid "Inspecting the selected image…"
msgstr "Inspeccionando la imagen seleccionada…"

#: src/app/window.c:554
msgid "Creating the MBR partition table…"
msgstr "Creando la tabla de particiones MBR…"

#: src/app/window.c:555
msgid "Creating the GPT partition table…"
msgstr "Creando la tabla de particiones GPT…"

#: src/app/window.c:563
msgid "Formatting the Fedora boot and persistence partitions…"
msgstr "Formateando las particiones de arranque y persistencia de Fedora…"

#: src/app/window.c:564
msgid "Formatting the Windows partition as FAT32…"
msgstr "Formateando la partición de Windows como FAT32…"

#: src/app/window.c:573
msgid "Mounting the new Fedora target…"
msgstr "Montando el nuevo destino de Fedora…"

#: src/app/window.c:574
msgid "Mounting the new Windows target…"
msgstr "Montando el nuevo destino de Windows…"

#: src/app/window.c:584
msgid "Copying Fedora boot and LiveOS files…"
msgstr "Copiando los archivos de arranque y LiveOS de Fedora…"

#: src/app/window.c:585
msgid "Copying Windows installation files…"
msgstr "Copiando los archivos de instalación de Windows…"

#: src/app/window.c:593
msgid "Configuring GRUB and persistent OverlayFS…"
msgstr "Configurando GRUB y OverlayFS persistente…"

#: src/app/window.c:594
msgid "Configuring GRUB for the extracted Fedora media…"
msgstr "Configurando GRUB para el medio Fedora extraído…"

#: src/app/window.c:600
msgid "Splitting install.wim for FAT32…"
msgstr "Dividiendo install.wim para FAT32…"

#: src/app/window.c:607
msgid "Writing the image to the USB device…"
msgstr "Escribiendo la imagen en el USB…"

#: src/app/window.c:618
msgid "Synchronizing Fedora media with the device…"
msgstr "Sincronizando el medio Fedora con el dispositivo…"

#: src/app/window.c:619
msgid "Synchronizing data with the device…"
msgstr "Sincronizando los datos con el dispositivo…"

#: src/app/window.c:629
msgid "Verifying every extracted Fedora file…"
msgstr "Verificando todos los archivos Fedora extraídos…"

#: src/app/window.c:630
msgid "Verifying the image by reading it back…"
msgstr "Verificando la imagen mediante lectura posterior…"

#: src/app/window.c:637
#, c-format
msgid "Stage %u of %u"
msgstr "Etapa %u de %u"

#: src/app/window.c:685
msgid "No additional diagnostic messages."
msgstr "No hay mensajes de diagnóstico adicionales."

#: src/app/window.c:698
msgid "Windows media completed, verified and safely unmounted"
msgstr "Medio de Windows completado, verificado y desmontado de forma segura"

#: src/app/window.c:702
msgid ""
"The BIOS/MBR Windows installation media was created successfully. The USB is "
"safely unmounted and can be disconnected."
msgstr ""
"El medio de instalación de Windows BIOS/MBR se creó correctamente. El USB "
"está desmontado de forma segura y puede desconectarse."

#: src/app/window.c:703
msgid ""
"The UEFI/GPT Windows installation media was created successfully. The USB is "
"safely unmounted and can be disconnected. Reconnect it to browse its files."
msgstr ""
"El medio de instalación de Windows UEFI/GPT se creó correctamente. El USB "
"está desmontado de forma segura y puede desconectarse. Vuelve a conectarlo "
"para explorar sus archivos."

#: src/app/window.c:709
msgid "Fedora media completed with persistence"
msgstr "Medio Fedora completado con persistencia"

#: src/app/window.c:710
msgid "Fedora media completed and verified"
msgstr "Medio Fedora completado y verificado"

#: src/app/window.c:714
msgid ""
"Fedora Live UEFI media with persistence was created, verified and safely "
"unmounted."
msgstr ""
"El medio Fedora Live UEFI con persistencia se creó, verificó y desmontó de "
"forma segura."

#: src/app/window.c:715
msgid "Fedora Live UEFI media was created, verified and safely unmounted."
msgstr ""
"El medio Fedora Live UEFI se creó, verificó y desmontó de forma segura."

#: src/app/window.c:718
msgid "Completed and verified"
msgstr "Completado y verificado"

#: src/app/window.c:720
msgid "The image was written and verified successfully."
msgstr "La imagen se escribió y verificó correctamente."

#: src/app/window.c:723
msgid "Completed"
msgstr "Completado"

#: src/app/window.c:725
msgid "The image was written without read-back verification."
msgstr "La imagen se escribió sin verificación mediante lectura posterior."

#: src/app/window.c:729
msgid "Cancelled"
msgstr "Cancelado"

#: src/app/window.c:730
msgid "The operation was cancelled."
msgstr "La operación fue cancelada."

#: src/app/window.c:732
msgid "Failed"
msgstr "Falló"

#: src/app/window.c:736
msgid "Writing failed without additional information."
msgstr "La escritura falló sin información adicional."

#: src/app/window.c:741
msgid "Unknown image"
msgstr "Imagen desconocida"

#: src/app/window.c:743
#, c-format
msgid ""
"Linux USB Creator operation report\n"
"Result: %s\n"
"Image: %s\n"
"Target: %s\n"
"%s\n"
"\n"
"Diagnostics:\n"
"%s\n"
msgstr ""
"Informe de operación de Linux USB Creator\n"
"Resultado: %s\n"
"Imagen: %s\n"
"Destino: %s\n"
"%s\n"
"\n"
"Diagnóstico:\n"
"%s\n"

#: src/app/window.c:751
msgid "Unknown device"
msgstr "Dispositivo desconocido"

#: src/app/window.c:794 src/app/window.c:1259
msgid "Elapsed time: 00:00"
msgstr "Tiempo transcurrido: 00:00"

#: src/app/window.c:795 src/app/window.c:1250
msgid "Waiting for authorization"
msgstr "Esperando autorización"

#: src/app/window.c:796
msgid "Preparing operation…"
msgstr "Preparando la operación…"

#: src/app/window.c:799
msgid "Waiting for authorization…"
msgstr "Esperando autorización…"

#: src/app/window.c:801
msgid "Authorize the limited Linux USB Creator helper."
msgstr "Autoriza el helper limitado de Linux USB Creator."

#: src/app/window.c:840
msgid "This operation will destroy all data on the USB device"
msgstr "Esta operación destruirá todos los datos del USB"

#: src/app/window.c:852
msgid "Confirm destructive write"
msgstr "Confirmar escritura destructiva"

#: src/app/window.c:867
#, c-format
msgid ""
"Target: %s (%s, %s)\n"
"Image: %s\n"
"Mode: Windows BIOS/MBR · FAT32"
msgstr ""
"Destino: %s (%s, %s)\n"
"Imagen: %s\n"
"Modo: Windows BIOS/MBR · FAT32"

#: src/app/window.c:868
#, c-format
msgid ""
"Target: %s (%s, %s)\n"
"Image: %s\n"
"Mode: Windows UEFI/GPT · FAT32"
msgstr ""
"Destino: %s (%s, %s)\n"
"Imagen: %s\n"
"Modo: Windows UEFI/GPT · FAT32"

#: src/app/window.c:873
#, c-format
msgid ""
"Target: %s (%s, %s)\n"
"Image: %s\n"
"Mode: Fedora Live UEFI/GPT · persistent"
msgstr ""
"Destino: %s (%s, %s)\n"
"Imagen: %s\n"
"Modo: Fedora Live UEFI/GPT · persistente"

#: src/app/window.c:874
#, c-format
msgid ""
"Target: %s (%s, %s)\n"
"Image: %s\n"
"Mode: Fedora Live UEFI/GPT"
msgstr ""
"Destino: %s (%s, %s)\n"
"Imagen: %s\n"
"Modo: Fedora Live UEFI/GPT"

#: src/app/window.c:878
#, c-format
msgid ""
"Target: %s (%s, %s)\n"
"Image: %s"
msgstr ""
"Destino: %s (%s, %s)\n"
"Imagen: %s"

#: src/app/window.c:884
msgid "Type ERASE to confirm:"
msgstr "Escribe BORRAR para confirmar:"

#: src/app/window.c:891
msgid "Erase and write"
msgstr "Borrar y escribir"

#: src/app/window.c:920
msgid "The image no longer exists or is no longer a regular file."
msgstr "La imagen ya no existe o dejó de ser un archivo regular."

#: src/app/window.c:950
msgid "Cancelling safely…"
msgstr "Cancelando de forma segura…"

#: src/app/window.c:978
msgid "Unable to export diagnostics."
msgstr "No se pudo exportar el diagnóstico."

#: src/app/window.c:991
msgid "Export operation diagnostics"
msgstr "Exportar diagnóstico de la operación"

#: src/app/window.c:994
msgid "Export"
msgstr "Exportar"

#: src/app/window.c:1109
msgid "Linux USB Creator"
msgstr "Creador de USB Linux"

#: src/app/window.c:1121
msgid "1. Select an image"
msgstr "1. Selecciona una imagen"

#: src/app/window.c:1127
msgid "ISO/raw image"
msgstr "Imagen ISO/raw"

#: src/app/window.c:1128
msgid "No image selected"
msgstr "Ninguna imagen seleccionada"

#: src/app/window.c:1129
msgid "Choose…"
msgstr "Elegir…"

#: src/app/window.c:1131
msgid "Choose an image (Ctrl+O)"
msgstr "Elegir una imagen (Ctrl+O)"

#: src/app/window.c:1142
msgid "Full verification"
msgstr "Verificación completa"

#: src/app/window.c:1144
msgid "Read the written image back and compare SHA-256"
msgstr "Lee nuevamente la imagen escrita y compara SHA-256"

#: src/app/window.c:1155
msgid "Windows partition scheme"
msgstr "Esquema de partición de Windows"

#: src/app/window.c:1157
msgid "Choose the firmware used by the target computer"
msgstr "Elige el firmware que usa el equipo de destino"

#: src/app/window.c:1162
msgid "Linux writing mode"
msgstr "Modo de escritura Linux"

#: src/app/window.c:1164
msgid "Choose raw compatibility or extracted Fedora UEFI media"
msgstr "Elige compatibilidad raw o un medio Fedora UEFI extraído"

#: src/app/window.c:1171
msgid "Persistent Fedora session"
msgstr "Sesión Fedora persistente"

#: src/app/window.c:1173
msgid "Keep Live session changes in the ext4 data partition"
msgstr "Conserva los cambios de la sesión Live en la partición de datos ext4"

#: src/app/window.c:1185
msgid "2. Select the target USB device"
msgstr "2. Selecciona el USB de destino"

#: src/app/window.c:1186
msgid "Scanning UDisks2…"
msgstr "Analizando UDisks2…"

#: src/app/window.c:1197
msgid "3. Confirm and write"
msgstr "3. Confirma y escribe"

#: src/app/window.c:1198
msgid ""
"The system SSD and ineligible devices remain blocked. Writing requires "
"explicit confirmation and Polkit authorization."
msgstr ""
"El SSD del sistema y los dispositivos no elegibles permanecen bloqueados. La "
"escritura requiere confirmación explícita y autorización Polkit."

#: src/app/window.c:1204 src/app/window.c:1212
msgid "Choose an image and an available USB device."
msgstr "Elige una imagen y un dispositivo USB disponible."

#: src/app/window.c:1210
msgid "Ready"
msgstr "Preparado"

#: src/app/window.c:1216
msgid "Cancel operation"
msgstr "Cancelar operación"

#: src/app/window.c:1218
msgid "Write image…"
msgstr "Escribir imagen…"

#: src/app/window.c:1220
msgid "Review and write (Ctrl+Enter)"
msgstr "Revisar y escribir (Ctrl+Enter)"

#: src/app/window.c:1243
msgid "Creating bootable media"
msgstr "Creando medio de arranque"

#: src/app/window.c:1255
msgid "No bytes processed yet"
msgstr "Aún no se han procesado bytes"

#: src/app/window.c:1265
msgid "Export diagnostics"
msgstr "Exportar diagnóstico"

#: src/app/window.c:1268
msgid "Back to setup"
msgstr "Volver a la configuración"

