<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.zsk1dr0w.LinuxUsbCreator</id>
  <name>Linux USB Creator</name>
  <name xml:lang="es">Creador de USB Linux</name>
  <summary>Safely create bootable USB media</summary>
  <summary xml:lang="es">Crea medios USB de arranque de forma segura</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <description>
    <p>
      Linux USB Creator is a native Linux utility for inspecting removable USB
      storage and creating verified bootable media from raw/hybrid images.
    </p>
    <p>
      Version 0.2 adds conservative, Polkit-authorized raw image writing with
      device identity revalidation and complete read-back verification.
    </p>
  </description>
  <launchable type="desktop-id">io.github.zsk1dr0w.LinuxUsbCreator.desktop</launchable>
  <url type="homepage">https://github.com/Zsk1dr0W/linuxusbcreator</url>
  <url type="bugtracker">https://github.com/Zsk1dr0W/linuxusbcreator/issues</url>
  <developer id="io.github.zsk1dr0w">
    <name>Víctor Díaz Gonzalez</name>
  </developer>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="0.5.1" date="2026-07-20">
      <description>
        <p>UEFI/GPT Windows media now uses a visible Microsoft Basic Data partition while retaining removable-media boot support.</p>
        <p>Validated file-manager visibility on Windows and Linux and x64 boot on physical UEFI/GPT and BIOS/MBR hardware.</p>
      </description>
    </release>
    <release version="0.5.0" date="2026-07-20">
      <description>
        <p>Windows image detection, UEFI/GPT and BIOS/MBR profiles, per-stage progress and automatic WIM splitting.</p>
        <p>Fixed a UDisks timeout when mounting a freshly formatted Windows target.</p>
        <p>Validated UEFI/GPT and BIOS/MBR x64 media on physical hardware; ARM64 remains experimental.</p>
      </description>
    </release>
    <release version="0.4.0" date="2026-07-20">
      <description>
        <p>Functional graphical writer with confirmation, progress and cancellation.</p>
      </description>
    </release>
    <release version="0.3.1" date="2026-07-20">
      <description>
        <p>Document all command-line modes in the built-in help.</p>
      </description>
    </release>
    <release version="0.3.0" date="2026-07-20">
      <description>
        <p>First distributable release with localization and native packages.</p>
      </description>
    </release>
    <release version="0.2.0" date="2026-07-20">
      <description>
        <p>Raw image writer MVP with Polkit, UDisks2 and verification.</p>
      </description>
    </release>
    <release version="0.1.0" date="2026-07-20">
      <description>
        <p>Initial read-only device discovery milestone.</p>
      </description>
    </release>
  </releases>
</component>
